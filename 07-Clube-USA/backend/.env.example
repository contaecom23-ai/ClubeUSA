# =============================================
# Clube USA — Backend Environment Variables
# =============================================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# --- Supabase (server-side service_role only) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE-WITH-A-RANDOM-64-CHAR-STRING

# --- App URLs ---
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# --- Email (SMTP) ---
# Leave SMTP_HOST empty to use dev mode (verification link printed to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@clubeusa.com
