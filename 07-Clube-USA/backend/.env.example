# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key — NUNCA expor ao frontend

# App secret — gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60    # 1 hora
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email — "log" imprime no console (dev); "resend" ou "sendgrid" para produção
EMAIL_SERVICE=log
RESEND_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@clubeusa.com

# URLs
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5500

# CORS — separado por vírgula
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
