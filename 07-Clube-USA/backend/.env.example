# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontrado em: Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...         # public anon key (usada só para auth)
SUPABASE_SERVICE_ROLE_KEY=eyJ... # secret! nunca expor ao cliente
SUPABASE_JWT_SECRET=super-secret-jwt-token-from-dashboard

# ─── App ─────────────────────────────────────────────────────────────────────
# CORS: origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:3000,https://clubeusa.com

# Ambiente: development | production
APP_ENV=development
