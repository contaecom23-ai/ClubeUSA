# =======================================================================
# CLUBE USA — variáveis de ambiente (NUNCA commitar o .env real)
# Copie para .env e preencha os valores.
# =======================================================================

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
# Chave server-side (service_role). NUNCA expor ao cliente/browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- JWT ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=SUBSTITUA_POR_CHAVE_ALEATORIA_LONGA_MINIMO_32_CHARS
# Duração do access token em dias (7 = balanceia segurança e UX)
ACCESS_TOKEN_EXPIRE_DAYS=7
# Duração do refresh token em dias
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Email SMTP ---
# Deixe SMTP_HOST vazio para modo dev (emails são logados no console)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxx
SMTP_FROM=noreply@clubeusa.com

# --- App ---
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://clubeusa.com
