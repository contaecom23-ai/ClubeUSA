# Copie este arquivo para .env e preencha os valores
# NUNCA faça commit do arquivo .env

# ── Banco de dados (Supabase Postgres) ─────────────────────────────────────
# Obtenha em: Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU-PROJECT-REF.supabase.co:5432/postgres

# ── Segurança JWT ───────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Sem SMTP configurado o sistema ainda funciona; o link de confirmação é logado.
# Exemplos: smtp.sendgrid.net (porta 587), smtp.gmail.com (porta 587)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clubeusa.com

# ── Aplicação ─────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000
ENVIRONMENT=development

# Origens permitidas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
