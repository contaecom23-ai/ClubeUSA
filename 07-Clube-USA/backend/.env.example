# ─── BANCO DE DADOS (obrigatório) ───────────────────────────────────────────
# String de conexão PostgreSQL direto ao Supabase (ou qualquer Postgres)
# Supabase: Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres

# ─── JWT / SEGURANÇA (obrigatório) ──────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# CRÍTICO: definir um valor estável. Se não definido, gera um temporário que
# invalida todas as sessões a cada restart.
SECRET_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─── EMAIL (obrigatório para confirmação de cadastro) ────────────────────────
# Se não configurado, emails são exibidos no console (modo dev).
# Recomendado: Resend (resend.com) — free tier: 3000 emails/mês
# Config SMTP do Resend: host=smtp.resend.com, port=587, user=resend, password=[API_KEY]
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=[SUA_API_KEY_RESEND]
SMTP_FROM=noreply@clubeusa.com
SMTP_TLS=true

# ─── APP ────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://clubeusa.com
# JSON array de origens CORS permitidas
CORS_ORIGINS=["https://clubeusa.com","http://localhost:8000"]
# "development" habilita /docs (Swagger UI); "production" desabilita
ENVIRONMENT=development
