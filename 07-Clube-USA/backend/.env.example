# Copy to .env and fill in real values. NEVER commit .env.

# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_random_64_char_secret

# Supabase — use the service_role key (never the anon key)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY

# SMTP — see DECISOES.md for provider recommendation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@clubeusa.com

# URL where the frontend is hosted (used in confirmation email links)
FRONTEND_URL=http://localhost:8080

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# "development" or "production"
ENVIRONMENT=development
