# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # from Project Settings > API

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-a-random-64-char-string

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000           # change to https://clubeusa.com in prod
ENVIRONMENT=development                     # development | production | test

# ── Email ────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=log    → prints emails to stdout (dev default, no setup needed)
# EMAIL_PROVIDER=smtp   → sends real emails via SMTP
EMAIL_PROVIDER=log
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@clubeusa.com
EMAIL_FROM_NAME=Clube USA

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
