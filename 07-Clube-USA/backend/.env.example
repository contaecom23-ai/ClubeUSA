# ============================================================
# Clube USA - Variáveis de Ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
# ============================================================

# Banco de dados (Supabase PostgreSQL - connection string do Dashboard > Settings > Database)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres

# JWT - gere com: python -c "import secrets; print(secrets.token_hex(64))"
# OBRIGATÓRIO — a app rejeita iniciar sem este valor
SECRET_KEY=

# Ambiente
ENVIRONMENT=development

# CORS - origens permitidas, separadas por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email (SMTP) - use Mailtrap para dev, SendGrid/SES para prod
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clubeusa.com
SMTP_FROM_NAME=Clube USA

# URL base do frontend (para links no email de confirmação)
FRONTEND_URL=http://localhost:3000
