# Copie para .env e preencha com as credenciais reais.
# NUNCA commite o .env no repositório.

# Painel Supabase > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Painel Supabase > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=seu_jwt_secret_aqui

# Origens permitidas no CORS (separadas por vírgula em prod)
CORS_ORIGINS=["http://localhost:8080","http://localhost:3000"]

# development | production
ENVIRONMENT=development
