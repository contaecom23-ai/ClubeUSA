# ── Banco de dados (Supabase connection string) ───────────────────────────────
# Copie de: Supabase > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_VALOR_ALEATORIO_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
# console = imprime no terminal (desenvolvimento)
# resend  = usa Resend.com (https://resend.com)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@clubeusa.com
RESEND_API_KEY=

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
