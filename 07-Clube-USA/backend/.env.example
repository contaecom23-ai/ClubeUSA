# ── Obrigatórios ──────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=TROQUE_PARA_UM_VALOR_ALEATORIO_32_CHARS

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Em DEV (DEBUG=true), os e-mails são apenas logados no console.
# Em PROD, preencha com SendGrid SMTP, AWS SES, Resend etc.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SUA_CHAVE_SMTP
SMTP_FROM=noreply@clubeusa.com

# ── Aplicação ──────────────────────────────────────────────────────────────────
APP_NAME=Clube USA
APP_URL=https://clubeusa.com
DEBUG=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Separar múltiplas origens com vírgula
ALLOWED_ORIGINS=https://clubeusa.com,https://www.clubeusa.com
