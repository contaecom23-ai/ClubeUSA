# =============================================
# Clube USA — Backend — Variáveis de Ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================

# Supabase (encontre em: dashboard > Settings > API)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key — NUNCA exponha no frontend
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui  # Settings > API > JWT Secret

# App
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_COM_O_COMANDO_ACIMA

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Ambiente: development | production
ENVIRONMENT=development
