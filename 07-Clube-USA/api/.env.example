# ── Clube USA API — environment variables ────────────────────────────────────
# Copy to .env and fill in. Never commit .env to git.

# App
APP_NAME=Clube USA API
DEBUG=false
FRONTEND_URL=https://clubeusa.com   # No trailing slash

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_ME_GENERATE_RANDOM_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# Supabase — use SERVICE ROLE key, never the anon key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=REPLACE_ME_SERVICE_ROLE_KEY

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://clubeusa.com,https://www.clubeusa.com

# Email (SMTP) — works with SendGrid, Mailgun, Resend SMTP relay, SES, etc.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=REPLACE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@clubeusa.com
SMTP_TLS=true

# Rate limits (slowapi format: N/unit, e.g. 5/minute, 10/hour)
RATE_LIMIT_LOGIN=5/15minute
RATE_LIMIT_REGISTER=10/hour
RATE_LIMIT_RESEND=3/hour
