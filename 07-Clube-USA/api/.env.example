# Clube USA API — variáveis de ambiente
# Copie para .env e preencha os valores reais (NUNCA comite .env)

# -------------------------
# App
# -------------------------
ENVIRONMENT=development         # development | production
APP_URL=http://localhost:8000   # URL pública da API (para links nos e-mails)

# -------------------------
# Banco de dados (Supabase)
# -------------------------
# Formato: postgresql+asyncpg://user:pass@host:5432/dbname
# No Supabase: Project Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql+asyncpg://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres

# Para testes locais sem Supabase use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./test.db

# -------------------------
# Segurança JWT
# -------------------------
# OBRIGATÓRIO: gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

ACCESS_TOKEN_TTL_SECONDS=604800    # 7 dias
REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 dias

# -------------------------
# CORS (origens permitidas, separadas por vírgula)
# -------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -------------------------
# E-mail
# -------------------------
# Backend: "console" (dev) | "resend" | "sendgrid"
EMAIL_BACKEND=console
EMAIL_FROM=noreply@clubeusa.com
EMAIL_FROM_NAME=Clube USA

# Resend (https://resend.com) — preencha se EMAIL_BACKEND=resend
RESEND_API_KEY=

# SendGrid — preencha se EMAIL_BACKEND=sendgrid
SENDGRID_API_KEY=
