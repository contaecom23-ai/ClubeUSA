# ClubeUSA — variáveis de ambiente
# Copie para .env e preencha os valores reais
# NUNCA faça commit do .env real

# =============================================================
# OBRIGATÓRIO — app recusa iniciar em produção sem estes
# =============================================================

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_AQUI_MINIMO_32_CHARS

# Encontre no painel Supabase: Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...SEU_SERVICE_ROLE_KEY

# =============================================================
# EMAIL (necessário para enviar confirmação em produção)
# =============================================================

# "log" = apenas loga o token no console (dev/test)
# "resend" = Resend.com (recomendado; tier grátis: 3k/mês)
# "sendgrid" = SendGrid
EMAIL_PROVIDER=log

# Necessário para "resend" ou "sendgrid"
EMAIL_API_KEY=

# Remetente configurado no seu provedor de email
EMAIL_FROM=noreply@clubeusa.com

# =============================================================
# URLS
# =============================================================

FRONTEND_URL=http://localhost:8000
API_URL=http://localhost:8000

# Origins aceitas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# =============================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================

# development | production
ENVIRONMENT=development

# TTLs de token (dias)
ACCESS_TOKEN_TTL_DAYS=7
REFRESH_TOKEN_TTL_DAYS=30

# TTL do link de confirmação de email (horas)
EMAIL_CONFIRM_TOKEN_TTL_HOURS=24

# Rate limits (formato slowapi: "N/period")
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute

# =============================================================
# ADMIN (acesso ao endpoint /api/admin/metrics)
# =============================================================

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Compartilhe APENAS com o dono do produto — nunca exponha publicamente
ADMIN_KEY=
