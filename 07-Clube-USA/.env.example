# Clube USA — Variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env.
#
# Onde achar os valores:
#   https://app.supabase.com > seu projeto > Settings > API

# URL do projeto Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Chave de serviço (service_role) — NUNCA exponha no frontend ou em logs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Segredo JWT — Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# CORS — origens autorizadas (vírgula separado, sem espaço)
ALLOWED_ORIGINS=http://localhost:8000,https://clubeusa.com
